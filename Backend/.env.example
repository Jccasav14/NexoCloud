# NexoCloud Backend Environment Variables Template
# Copy this file to '.env' and fill in your actual credentials.

# URL de conexión a la base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/nombre_db

# Clave secreta para la generación y firma de tokens JWT
SECRET_KEY=tu_clave_secreta_aqui

# Proveedor de almacenamiento: 'local' (para disco local) o 's3' (para Amazon S3)
STORAGE_PROVIDER=local_o_s3

# Configuración de AWS S3 (Requerido solo si STORAGE_PROVIDER=s3)
# Nota: Si ejecutas 'aws configure' en tu máquina local y montas el volumen de AWS en Docker,
# puedes dejar las credenciales (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_SESSION_TOKEN) vacías.
S3_BUCKET_NAME=nombre_de_tu_bucket_aqui
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_access_key_id_aqui
AWS_SECRET_ACCESS_KEY=tu_secret_access_key_aqui
AWS_SESSION_TOKEN=tu_session_token_temporal_aqui
